# OpenAI-compatible API
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.7
# Number of user/assistant pairs retained per user. 0 disables history.
OPENAI_CONTEXT_TURNS=10
OPENAI_SYSTEM_PROMPT="你是一个有用的助手"

# Comma-separated ilink user IDs. Use * only when you intentionally allow everyone.
WEIXIN_ALLOW_FROM=your-ilink-user-id
WEIXIN_API_BASE_URL=https://ilinkai.weixin.qq.com
WEIXIN_BOT_TYPE=3

DATA_DIR=./data
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=60000
LONG_POLL_TIMEOUT_MS=35000
RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000
DEDUPE_MAX_SIZE=2000
SEND_ERROR_MESSAGE=true
